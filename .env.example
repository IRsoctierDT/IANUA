# .env.example — DOCUMENT KEYS ONLY. Never put real secrets here. (AGENTS.md §4-§5)
# Copy to .env (gitignored) and fill locally.

# --- Local LLM (Ollama) ---
OLLAMA_HOST=http://127.0.0.1:11434
LLM_MODEL=llama3.1

# --- RAG / vector store ---
VECTOR_STORE_PATH=./data/vectorstore
EMBEDDING_MODEL=nomic-embed-text
QDRANT_URL=http://127.0.0.1:6333

# --- Local lab stack (infra/docker-compose.yml) ---
# Postgres is provisioned to match the Environment Setup; set a local password.
POSTGRES_USER=aiocc
POSTGRES_DB=aiocc
# Leave blank here; set a local value in .env. Compose fails closed if unset/empty.
POSTGRES_PASSWORD=

# --- Runtime ---
LOG_LEVEL=INFO
# Default-deny egress; list explicit lab hosts only if a tool needs network.
ALLOWED_EGRESS_HOSTS=127.0.0.1,localhost
