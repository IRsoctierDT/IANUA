# .env.example — DOCUMENT KEYS ONLY. Never put real secrets here. (AGENTS.md §4-§5)
# Copy to .env (gitignored) and fill locally.

# --- Local LLM ---
LLM_MODEL=qwen3.5:9b   # Apache-2.0, ~6.6GB Q4, 256K context (pull: ollama pull qwen3.5:9b)
LLM_BACKEND=ollama     # ollama | llamacpp
LLM_NARRATIVE=auto     # auto (on if a local model is reachable) | on | off
OLLAMA_HOST=http://127.0.0.1:11434
LLAMACPP_HOST=http://127.0.0.1:8080   # llama-server (OpenAI-compatible /v1)

# --- RAG / vector store ---
VECTOR_STORE_PATH=./data/vectorstore
EMBEDDING_MODEL=nomic-embed-text
QDRANT_URL=http://127.0.0.1:6333

# --- Local lab stack (infra/docker-compose.yml) ---
# Postgres is provisioned to match the Environment Setup; set a local password.
POSTGRES_USER=aiocc
POSTGRES_DB=aiocc
# Leave blank here; set a local value in .env. Compose fails closed if unset/empty.
POSTGRES_PASSWORD=

# --- Runtime ---
LOG_LEVEL=INFO
# Default-deny egress; list explicit lab hosts only if a tool needs network.
ALLOWED_EGRESS_HOSTS=127.0.0.1,localhost

# --- Audit log ---
# Optional signing of the tamper-evident audit log's chain head
# (agents/policies/audit.py). Leave blank to disable. NEVER commit a real key.
# Symmetric (HMAC): a strong random secret; verifiers need this same value.
AUDIT_HMAC_KEY=
# Asymmetric (Ed25519, needs the .[crypto] extra): hex-encoded 32-byte raw keys.
# Sign with the private key; distribute only the public key to verifiers.
AUDIT_ED25519_PRIVATE_KEY=
AUDIT_ED25519_PUBLIC_KEY=
